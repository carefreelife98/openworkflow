{
  "name": "@openpipeline/server",
  "version": "0.1.0",
  "description": "Transport-agnostic HTTP + SSE handlers for OpenPipeline, with a tiny Node http adapter.",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openworkflow/tree/main/packages/server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openworkflow.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openworkflow/issues"
  },
  "keywords": [
    "pipeline",
    "sse",
    "http",
    "server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openpipeline/core": "workspace:*",
    "@openpipeline/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
