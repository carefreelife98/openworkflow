{
  "name": "@openpipeline/mcp",
  "version": "0.1.0",
  "description": "Optional MCP integration for OpenPipeline: JSON-Schema→Zod converter, MCP client factory, env catalog loader, and mcp:* node resolver.",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openpipeline/tree/main/packages/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openpipeline.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openpipeline/issues"
  },
  "keywords": [
    "pipeline",
    "mcp",
    "model-context-protocol",
    "tools"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openpipeline/core": "workspace:*",
    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.48",
    "zod": "^3.25.32 || ^4.2.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
