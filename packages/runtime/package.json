{
  "name": "@openpipeline/runtime",
  "version": "0.1.0",
  "description": "PipelineEngine orchestrator for OpenPipeline — drives a run end to end over the kernel.",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openpipeline/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openpipeline.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openpipeline/issues"
  },
  "keywords": [
    "pipeline",
    "engine",
    "langgraph",
    "orchestration"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
