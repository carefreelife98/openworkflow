{
  "name": "@openpipeline/react",
  "version": "0.1.0",
  "description": "Visual DAG builder for OpenPipeline as a controlled React component library (ReactFlow + Zustand).",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openworkflow/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openworkflow.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openworkflow/issues"
  },
  "keywords": [
    "pipeline",
    "builder",
    "reactflow",
    "react",
    "dag"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openpipeline/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@xyflow/react": ">=12",
    "@dagrejs/dagre": ">=1",
    "zustand": ">=5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@xyflow/react": "^12.3.5",
    "@dagrejs/dagre": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
