{
  "name": "@openpipeline/store-prisma",
  "version": "0.1.0",
  "description": "Postgres PipelineStore + StepRecorder adapter for OpenPipeline (Prisma).",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openworkflow/tree/main/packages/store-prisma#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openworkflow.git",
    "directory": "packages/store-prisma"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openworkflow/issues"
  },
  "keywords": [
    "pipeline",
    "store",
    "prisma",
    "postgres"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.prisma": "./prisma/schema.prisma"
  },
  "files": [
    "dist",
    "prisma"
  ],
  "sideEffects": false,
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openpipeline/core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=5"
  },
  "devDependencies": {
    "@prisma/client": "^6.1.0",
    "prisma": "^6.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
