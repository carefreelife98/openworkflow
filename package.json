{
  "name": "openworkflow",
  "version": "0.0.0",
  "private": true,
  "description": "A framework-agnostic engine for compiling and running MCP-tool workflows as LangGraph DAGs.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "example": "pnpm --filter @openworkflow/example-quickstart start"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
