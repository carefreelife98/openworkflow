{
  "name": "openpipeline",
  "version": "0.0.0",
  "private": true,
  "description": "A framework-agnostic engine for compiling and running MCP-tool pipelines as LangGraph DAGs.",
  "license": "MIT",
  "author": "carefreelife98",
  "homepage": "https://github.com/carefreelife98/openworkflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carefreelife98/openworkflow.git"
  },
  "bugs": {
    "url": "https://github.com/carefreelife98/openworkflow/issues"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "example": "pnpm --filter @openpipeline/example-quickstart start"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
